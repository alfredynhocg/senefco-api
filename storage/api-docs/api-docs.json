    "components": {
        "schemas": {
            "ClienteItem": {
                "description": "Cliente en listado paginado",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nombre": {
                        "type": "string",
                        "example": "Juan Pérez"
                    },
                    "tipo": {
                        "type": "string",
                        "enum": [
                            "natural",
                            "juridico"
                        ],
                        "example": "natural"
                    },
                    "nit_ci": {
                        "type": "string",
                        "example": "12345678",
                        "nullable": true
                    },
                    "email": {
                        "type": "string",
                        "example": "juan@ejemplo.com",
                        "nullable": true
                    },
                    "telefono": {
                        "type": "string",
                        "example": "76543210",
                        "nullable": true
                    },
                    "direccion": {
                        "type": "string",
                        "example": "Av. Principal 123",
                        "nullable": true
                    },
                    "ciudad": {
                        "type": "string",
                        "example": "La Paz",
                        "nullable": true
                    },
                    "activo": {
                        "type": "boolean",
                        "example": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "CompraItem": {
                "description": "Compra en listado paginado",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "numero_compra": {
                        "type": "string",
                        "example": "COM-2026-0001"
                    },
                    "proveedor_nombre": {
                        "type": "string",
                        "example": "Distribuidora ABC",
                        "nullable": true
                    },
                    "proveedor_id": {
                        "type": "integer",
                        "example": 3
                    },
                    "estado": {
                        "type": "string",
                        "enum": [
                            "pendiente",
                            "recibido",
                            "cancelado"
                        ],
                        "example": "pendiente"
                    },
                    "subtotal": {
                        "type": "number",
                        "example": 1500
                    },
                    "descuento": {
                        "type": "number",
                        "example": 0
                    },
                    "total": {
                        "type": "number",
                        "example": 1500
                    },
                    "fecha_compra": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-02-15",
                        "nullable": true
                    },
                    "observaciones": {
                        "type": "string",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "DepartamentoItem": {
                "description": "Departamento de Bolivia",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "nombre": {
                        "type": "string",
                        "example": "La Paz"
                    },
                    "slug": {
                        "type": "string",
                        "example": "la-paz"
                    },
                    "descripcion": {
                        "type": "string",
                        "example": "Capital del Estado Plurinacional",
                        "nullable": true
                    },
                    "nro_habitantes": {
                        "type": "integer",
                        "example": 2800000,
                        "nullable": true
                    },
                    "activo": {
                        "type": "boolean",
                        "example": true
                    },
                    "imagen": {
                        "type": "string",
                        "example": "departamentos/la-paz.jpg",
                        "nullable": true
                    },
                    "fecha_festiva": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-07-16",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "MovimientoInventarioItem": {
                "description": "Movimiento de inventario",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "producto_id": {
                        "type": "integer",
                        "example": 5
                    },
                    "producto_nombre": {
                        "type": "string",
                        "example": "Azúcar 1kg",
                        "nullable": true
                    },
                    "tipo_movimiento": {
                        "type": "string",
                        "enum": [
                            "entrada",
                            "salida",
                            "ajuste",
                            "devolucion"
                        ]
                    },
                    "cantidad": {
                        "type": "integer",
                        "example": 100
                    },
                    "stock_anterior": {
                        "type": "integer",
                        "example": 50,
                        "nullable": true
                    },
                    "stock_nuevo": {
                        "type": "integer",
                        "example": 150,
                        "nullable": true
                    },
                    "motivo": {
