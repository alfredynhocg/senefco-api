        "/departamentos": {
            "get": {
                "tags": [
                    "Departamentos"
                ],
                "summary": "Listar departamentos paginados",
                "operationId": "daf69d839fb0787fc719b8262f1b56cc",
                "parameters": [
                    {
                        "name": "pageIndex",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "pageSize",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    },
                    {
                        "name": "query",
                        "in": "query",
                        "description": "Buscar por nombre",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "sort[key]",
                        "in": "query",
                        "description": "Campo de orden: nombre, nro_habitantes, created_at",
                        "schema": {
                            "type": "string",
                            "default": "nombre"
                        }
                    },
                    {
                        "name": "sort[order]",
                        "in": "query",
                        "description": "Dirección: asc o desc",
                        "schema": {
                            "type": "string",
                            "default": "asc"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista paginada de departamentos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/DepartamentoItem"
                                            }
                                        },
                                        "total": {
                                            "type": "integer",
                                            "example": 9
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Departamentos"
                ],
                "summary": "Crear un nuevo departamento",
                "operationId": "904d4aa423caf554d2d0b2d0a52d6474",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "nombre"
                                ],
                                "properties": {
                                    "nombre": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "example": "Oruro"
                                    },
                                    "descripcion": {
                                        "type": "string",
                                        "example": "Departamento minero de Bolivia",
                                        "nullable": true
                                    },
                                    "nro_habitantes": {
                                        "type": "integer",
                                        "example": 494587,
                                        "nullable": true
                                    },
                                    "activo": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "imagen": {
                                        "type": "string",
                                        "example": "departamentos/oruro.jpg",
                                        "nullable": true
                                    },
                                    "fecha_festiva": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2026-02-10",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Departamento creado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DepartamentoItem"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Error de validación"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Departamentos"
                ],
                "summary": "Eliminar departamento(s)",
                "description": "Eliminación lógica (soft delete). Acepta un ID individual o un array de IDs.",
                "operationId": "009fe30a0363830ce9d7c6fd18df4d0f",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id": {
                                        "description": "ID individual o array de IDs",
                                        "oneOf": [
                                            {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            {
                                                "type": "array",
                                                "items": {
                                                    "type": "integer"
                                                },
                                                "example": [
                                                    1,
                                                    2,
                                                    3
                                                ]
                                            }
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Eliminado correctamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "boolean"
                                },
                                "example": true
                            }
                        }
                    },
                    "404": {
                        "description": "Departamento no encontrado"
                    }
                }
            }
        },
